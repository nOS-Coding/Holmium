/* holmium.script ‚ÄĒ Holmium OS Plymouth theme */

/* Black background */
Window.SetBackgroundTopColor(0.0, 0.0, 0.0);
Window.SetBackgroundBottomColor(0.0, 0.0, 0.0);

/* Holmium ASCII logo in white */
fun draw_logo()
{
    /* 6-line Holmium block logo centered */
    logo_lines = [
        "‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó",
        "‚ēö‚ēź‚ēź‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ",
        "   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚Ėą‚Ėą‚ēĎ ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ",
        "   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ  ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ",
        "   ‚Ėą‚Ėą‚ēĎ   ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ ‚ēö‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ   ",
        "   ‚ēö‚ēź‚ēĚ    ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ     ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   "
    ];

    /* Calculate centering */
    screen_width = Window.GetWidth();
    screen_height = Window.GetHeight();
    logo_width = 56;  /* characters wide */
    char_width = 10;  /* approximate */
    char_height = 20;
    logo_pixel_width = logo_width * char_width;
    logo_pixel_height = 6 * char_height;
    x_offset = (screen_width - logo_pixel_width) / 2;
    y_offset = (screen_height - logo_pixel_height) / 2 - 30;

    /* Draw each line */
    for (i = 0; i < 6; i++) {
        line = logo_lines[i];
        text = Text(line);
        text.SetColor(1.0, 1.0, 1.0, 1.0);  /* white */
        text.SetPosition(x_offset, y_offset + (i * char_height));
        text.Show();
    }
}

/* Progress bar at bottom */
fun draw_progress_bar(progress)
{
    screen_width = Window.GetWidth();
    screen_height = Window.GetHeight();
    bar_width = screen_width * 0.5;
    bar_height = 6;
    bar_x = (screen_width - bar_width) / 2;
    bar_y = screen_height - 60;

    /* Background bar (dark gray) */
    bg_bar = Rectangle(bar_x, bar_y, bar_width, bar_height);
    bg_bar.SetColor(0.2, 0.2, 0.2, 1.0);
    bg_bar.Show();

    /* Progress fill (white) */
    fill_width = bar_width * progress;
    if (fill_width > 0) {
        fill_bar = Rectangle(bar_x, bar_y, fill_width, bar_height);
        fill_bar.SetColor(1.0, 1.0, 1.0, 1.0);
        fill_bar.Show();
    }
}

/* "HOLMIUM OS" subtitle below logo */
fun draw_subtitle()
{
    screen_width = Window.GetWidth();
    screen_height = Window.GetHeight();
    subtitle = Text("HOLMIUM OS");
    subtitle.SetColor(0.6, 0.6, 0.6, 1.0);  /* gray */
    subtitle.SetPosition(screen_width / 2 - 40, screen_height / 2 + 50);
    subtitle.Show();
}

/* Main animation loop */
fun refresh_callback()
{
    progress = Plymouth.GetMode() == "boot" ?
        Plymouth.GetProgress() : 1.0;

    /* Only draw on boot mode */
    if (Plymouth.GetMode() == "boot") {
        draw_logo();
        draw_subtitle();
        draw_progress_bar(progress);
    }
}
